# LV UP — 환경변수 템플릿
#
# 이 파일은 Git에 커밋된다. 실제 값은 .env.local에 입력하고 커밋하지 말 것.
# 3계층 구조는 docs/TECH_SPEC.md Section 17 참조.
#
# 로컬 개발은 cp .env.example .env.local 후 값을 채워 넣는다.

# ──────────────────────────────────────────────────────────
# Cloudflare 계정 / 리소스 (drizzle-kit / wrangler CLI용)
# ──────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=f32eace9e00ef37eeee1b87602878c15
CLOUDFLARE_DATABASE_ID=
CLOUDFLARE_API_TOKEN=

# ──────────────────────────────────────────────────────────
# 인증 시크릿
# 생성 방법(Windows PowerShell):
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))
# Git Bash / WSL:
#   openssl rand -base64 32
# Node (any OS):
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ──────────────────────────────────────────────────────────
AUTH_SECRET=

# ──────────────────────────────────────────────────────────
# 앱
# ──────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
